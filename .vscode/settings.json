{
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.formatOnSave": true,
  "editor.guides.indentation": true,
  "editor.tabSize": 2,
  "search.exclude": {
    "**/node_modules": true,
    "**/vendor": true,
    "*.lock": true,
    "*lock.json": true,
    "pnpm*": true
  },
  "files.associations": {
    "*.css": "tailwindcss"
  },
  "[svelte]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[go]": {
    "editor.defaultFormatter": "golang.go",
    "editor.tabSize": 4
  }
}
